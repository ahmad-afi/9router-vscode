{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:go",
      "type": "shell",
      "command": "go build -o ../bin/engine .",
      "options": { "cwd": "${workspaceFolder}/go" },
      "problemMatcher": ["$go"]
    },
    {
      "label": "build:ts",
      "type": "shell",
      "command": "npx esbuild src/extension.ts --bundle --outfile=dist/extension.js --platform=node --external:vscode --format=cjs",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build",
      "dependsOn": ["build:go", "build:ts"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
